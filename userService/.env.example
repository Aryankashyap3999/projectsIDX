# Port the service listens on (host platforms like Render inject their own PORT).
PORT=3000

# development | production — selects which DB URL the app uses.
NODE_ENV=development

# MongoDB connection strings (use a separate user/password per environment).
DEV_DB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
PROD_DB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Email verification flow.
ENABLE_EMAIL_VERIFICATION=false

# SMTP credentials for Nodemailer (e.g. Gmail app password).
MAIL_ID=your-email@example.com
MAIL_PASSWORD=your-app-password

# Redis for Bull queues (Upstash / Redis Cloud in prod).
REDIS_HOST=localhost
REDIS_PORT=6379

# Public URL of the frontend, used in verification emails.
APP_LINK=http://localhost:5173

# Auth.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY=1d

# Allowed CORS origins (comma-separated). Leave unset in dev to allow all.
# e.g. https://your-frontend.vercel.app
CORS_ORIGIN=

# Basic-auth credentials protecting the Bull Board UI at /ui.
# Required in production, otherwise /ui returns 403.
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=change-me
